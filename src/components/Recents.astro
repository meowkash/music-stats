---
// Recents component - displaying recent scrobbles feed
---

<div class="recents-container glass-card feed-section">
  <div class="view-header">
    <h2>Recents</h2>
    <p class="subtitle">Recently, I have been jamming to...</p>
  </div>
  <div class="recent-list" id="recentPlaysList">
    <!-- Injected by client JS -->
  </div>
</div>

<style>
  .recents-container {
    width: 100%;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 24px;
    min-height: 50vh;
  }

  .recent-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Scrobble row overrides */
  .recent-list :global(.scrobble-row) {
    padding: 12px 16px;
    gap: 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 12px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .recent-list :global(.scrobble-row:hover) {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
  }

  .recent-list :global(.scrobble-row-thumb) {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .recent-list :global(.scrobble-row-thumb img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .recent-list :global(.scrobble-row-thumb svg) {
    width: 20px;
    height: 20px;
    color: var(--text-muted);
  }

  .recent-list :global(.scrobble-row-info) {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    min-width: 0;
  }

  .recent-list :global(.scrobble-row-title) {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 2px;
  }

  .recent-list :global(.scrobble-row-subtitle) {
    font-size: 12px;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .recent-list :global(.scrobble-row-right) {
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    font-weight: 500;
  }
</style>

<script>
  import {
    generateScrobbleRowHTML,
    applyCountGlows,
    getArtworkUrl,
  } from "../utils/ui";

  interface RecentScrobble {
    uts: number;
    artist: string;
    album: string;
    track: string;
    trackId: number;
  }

  document.addEventListener("DOMContentLoaded", () => {
    // Relative time formatting
    function formatRelativeTime(uts: number): string {
      const diff = Math.floor(Date.now() / 1000) - uts;
      if (diff < 60) return "Just now";
      if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
      if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
      return `${Math.floor(diff / 86400)}d ago`;
    }

    async function loadRecentPlays() {
      const container = document.getElementById("recentPlaysList");
      if (!container) return;

      try {
        const [recentRes, metaRes, artworkRes] = await Promise.all([
          fetch("/data/recent.json"),
          fetch("/data/meta.json"),
          fetch("/data/artwork.json").catch(() => null),
        ]);

        const list: RecentScrobble[] = await recentRes.json();
        const meta = await metaRes.json();
        let artworkCache: Record<string, string> = {};
        if (artworkRes && artworkRes.ok) {
          artworkCache = await artworkRes.json();
        }

        if (!list || list.length === 0) {
          container.innerHTML =
            '<div class="no-data-message">No recent activity</div>';
          return;
        }

        container.innerHTML = list
          .map((item) => {
            const imgUrl = getArtworkUrl(
              "track",
              item.track,
              item.artist,
              item.album,
              artworkCache,
            );

            return generateScrobbleRowHTML(
              {
                type: "track",
                id: item.trackId,
                name: item.track,
                subtitle: `${item.album} • ${item.artist}`,
                imgUrl: imgUrl || null,
                count: formatRelativeTime(item.uts),
              },
              false,
            );
          })
          .join("");

        // Wire click triggers
        const rows = container.querySelectorAll(".clickable-entity");
        rows.forEach((row) => {
          row.addEventListener("click", () => {
            const type = row.getAttribute("data-type");
            const idStr = row.getAttribute("data-id");
            if (type && idStr) {
              window.dispatchEvent(
                new CustomEvent("open-entity-details", {
                  detail: { type, id: parseInt(idStr, 10) },
                }),
              );
            }
          });
        });
      } catch (err) {
        console.error("Failed to load recent scrobbles:", err);
      }
    }

    loadRecentPlays();
    window.addEventListener("refresh-data", loadRecentPlays);
  });
</script>
