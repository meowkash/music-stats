---
// Recents component - displaying recent scrobbles feed
---

<div class="recents-container glass-card feed-section">
  <div class="section-header">
    <h2>Recent Plays</h2>
    <p class="subtitle">Your latest listening activity</p>
  </div>
  <div class="recent-list" id="recentPlaysList">
    <!-- Injected by client JS -->
  </div>
</div>

<style>
  .recents-container {
    width: 100%;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 24px;
    min-height: 50vh;
  }

  .section-header h2 {
    font-family: var(--font-header);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #fff 30%, var(--text-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-header .subtitle {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .recent-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Scrobble row overrides */
  .recent-list :global(.scrobble-row) {
    padding: 12px 16px;
    gap: 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 12px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .recent-list :global(.scrobble-row:hover) {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
  }

  .recent-list :global(.scrobble-row-thumb) {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .recent-list :global(.scrobble-row-thumb img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .recent-list :global(.scrobble-row-thumb svg) {
    width: 20px;
    height: 20px;
    color: var(--text-muted);
  }

  .recent-list :global(.scrobble-row-info) {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    min-width: 0;
  }

  .recent-list :global(.scrobble-row-title) {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 2px;
  }

  .recent-list :global(.scrobble-row-subtitle) {
    font-size: 12px;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .recent-list :global(.scrobble-row-right) {
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    font-weight: 500;
  }
</style>

<script>
  interface RecentScrobble {
    uts: number;
    artist: string;
    album: string;
    track: string;
  }

  document.addEventListener("DOMContentLoaded", () => {
    // Escape HTML utility function to prevent XSS
    function escapeHTML(str: string): string {
      return str
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    // Relative time formatting
    function formatRelativeTime(uts: number): string {
      const diff = Math.floor(Date.now() / 1000) - uts;
      if (diff < 60) return "Just now";
      if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
      if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
      return `${Math.floor(diff / 86400)}d ago`;
    }

    async function loadRecentPlays() {
      const container = document.getElementById("recentPlaysList");
      if (!container) return;

      try {
        const [recentRes, metaRes, artworkRes] = await Promise.all([
          fetch("/data/recent.json"),
          fetch("/data/meta.json"),
          fetch("/data/artwork.json").catch(() => null),
        ]);

        const list: RecentScrobble[] = await recentRes.json();
        const meta = await metaRes.json();
        let artworkCache: Record<string, string> = {};
        if (artworkRes && artworkRes.ok) {
          artworkCache = await artworkRes.json();
        }

        if (!list || list.length === 0) {
          container.innerHTML =
            '<div class="no-data" style="text-align: center; color: var(--text-muted); padding: 40px 0;">No recent activity</div>';
          return;
        }

        // Map artist name to ID lookup
        const artistIdsByName: Record<string, number> = {};
        if (meta && meta.artists) {
          for (const [idStr, name] of Object.entries(meta.artists)) {
            artistIdsByName[(name as string).toLowerCase()] = parseInt(
              idStr,
              10,
            );
          }
        }

        container.innerHTML = list
          .map((item) => {
            const imgUrl =
              artworkCache[`${item.album}|${item.artist}`] ||
              artworkCache[item.artist];
            const highResImg = imgUrl
              ? imgUrl.replace("/300x300/", "/500x500/") // Keep last.fm upgrade
              : null;
            const thumbContent = highResImg
              ? `<img src="${highResImg}" alt="Cover">`
              : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                 <path d="M9 18V5l12-2v13"></path>
                 <circle cx="6" cy="18" r="3"></circle>
                 <circle cx="18" cy="16" r="3"></circle>
               </svg>`;

            const artistId = artistIdsByName[item.artist.toLowerCase()] || 0;

            return `
            <div class="scrobble-row clickable-recent-row" data-type="artist" data-id="${artistId}">
              <div class="scrobble-row-thumb">
                ${thumbContent}
              </div>
              <div class="scrobble-row-info">
                <span class="scrobble-row-title">${escapeHTML(item.track)}</span>
                <span class="scrobble-row-subtitle">${escapeHTML(item.artist)} • ${escapeHTML(item.album)}</span>
              </div>
              <span class="scrobble-row-right">${formatRelativeTime(item.uts)}</span>
            </div>
          `;
          })
          .join("");

        // Wire click triggers
        const rows = container.querySelectorAll(".clickable-recent-row");
        rows.forEach((row) => {
          row.addEventListener("click", () => {
            const type = row.getAttribute("data-type");
            const idStr = row.getAttribute("data-id");
            if (type && idStr && idStr !== "0") {
              window.dispatchEvent(
                new CustomEvent("open-entity-details", {
                  detail: { type, id: parseInt(idStr, 10) },
                }),
              );
            }
          });
        });
      } catch (err) {
        console.error("Failed to load recent scrobbles:", err);
      }
    }

    loadRecentPlays();
    window.addEventListener("refresh-data", loadRecentPlays);
  });
</script>
