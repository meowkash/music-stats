---
// YearlyCompare component
---

<div class="compare-container glass-card">
  <div class="view-header">
    <h2>Statistics</h2>
    <p class="subtitle">Welcome to my nerdy side...</p>
  </div>

  <!-- Chart Controls -->
  <div class="chart-controls">
    <div class="control-group">
      <span class="control-label">Select Years</span>
      <div class="year-checkbox-group" id="yearCheckboxes">
        <!-- Injected by client JS -->
      </div>
    </div>
  </div>

  <!-- Chart Display Canvas -->
  <div class="chart-wrapper">
    <div class="chart-canvas-container">
      <canvas id="yearlyCompareChart"></canvas>
    </div>
  </div>

  <!-- Mobile Swipe Indicator (Only visible on small screens) -->
  <div class="mobile-swipe-indicator">
    <svg
      viewBox="0 0 24 24"
      width="14"
      height="14"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
    >
    Swipe horizontally to explore
    <svg
      viewBox="0 0 24 24"
      width="14"
      height="14"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="M7 16l-4-4m0 0l4-4m-4 4h20"></path></svg
    >
  </div>

  <!-- Yearly Stats View -->
  <div class="yearly-stats-container">
    <div class="yearly-stats-card" id="activeStatsCard">
      <div class="yearly-stats-header" id="statsCardHeader">
        <div class="custom-dropdown" id="yearDropdownContainer">
          <button class="dropdown-trigger" id="yearDropdownBtn">
            <span id="yearDropdownText">Year</span>
            <svg
              viewBox="0 0 24 24"
              width="14"
              height="14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg
            >
          </button>
          <div class="dropdown-popover" id="yearDropdownPopover"></div>
        </div>

        <h3>Top</h3>

        <div class="custom-dropdown" id="categoryDropdownContainer">
          <button class="dropdown-trigger" id="categoryDropdownBtn">
            <span id="categoryDropdownText">Songs</span>
            <svg
              viewBox="0 0 24 24"
              width="14"
              height="14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg
            >
          </button>
          <div class="dropdown-popover" id="categoryDropdownPopover">
            <div class="dropdown-item" data-val="tracks">Songs</div>
            <div class="dropdown-item" data-val="albums">Albums</div>
            <div class="dropdown-item" data-val="artists">Artists</div>
          </div>
        </div>
      </div>

      <div class="stats-list" id="activeStatsList">
        <!-- Injected by client JS -->
      </div>
    </div>
  </div>
</div>

<style>
  .compare-container {
    width: 100%;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 24px;
  }

  /* Controls */
  .chart-controls {
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 16px;
    border-radius: 6px;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .control-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .year-checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .year-checkbox-group :global(.checkbox-label) {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    user-select: none;
    color: var(--year-color);
    opacity: 0.6;
  }

  .year-checkbox-group :global(.checkbox-label:hover) {
    background: rgba(255, 255, 255, 0.04);
    opacity: 0.85;
    border-color: rgba(255, 255, 255, 0.15);
  }

  .year-checkbox-group :global(.checkbox-label input) {
    display: none;
  }

  /* LED indicator styling */
  .year-checkbox-group :global(.led-indicator) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    flex-shrink: 0;
    box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.6);
  }

  /* Checked/selected state */
  .year-checkbox-group :global(.checkbox-label.checked) {
    opacity: 1;
    border-color: var(--year-color);
    background: rgba(255, 255, 255, 0.05);
    box-shadow:
      0 0 12px var(--year-color-glow),
      inset 0 0 4px var(--year-color-glow);
  }

  .year-checkbox-group :global(.checkbox-label.checked .led-indicator) {
    background: var(--year-color);
    border-color: #fff;
    box-shadow:
      0 0 8px var(--year-led-glow),
      0 0 16px var(--year-color-glow),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .mobile-swipe-indicator {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 12px 0 0 0;
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    animation: pulse 2s infinite;
  }

  @media (max-width: 768px) {
    .mobile-swipe-indicator {
      display: flex;
    }
  }

  /* Canvas */
  .chart-wrapper {
    position: relative;
    width: 100%;
    height: 350px;
    background: rgba(0, 0, 0, 0.1);
    border-radius: 16px;
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.02);
  }

  .chart-canvas-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  canvas {
    width: 100% !important;
    height: 100% !important;
  }

  /* Yearly Stats Carousel */
  .yearly-stats-container {
    margin-top: 16px;
    flex-direction: column;
    gap: 8px;
  }

  .yearly-stats-container :global(.yearly-stats-card) {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: rgba(20, 20, 25, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 20px;
    padding: 20px;
    flex-shrink: 0;
    width: 100%;
    scroll-snap-align: start;
  }

  .yearly-stats-container :global(.yearly-stats-header) {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .yearly-stats-container :global(.yearly-stats-header h3) {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
  }

  /* Custom Dropdowns */
  .custom-dropdown {
    position: relative;
  }

  .dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 6px 14px;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    font-family: var(--font-header);
    cursor: pointer;
    transition: var(--transition-smooth);
    user-select: none;
  }

  .dropdown-trigger:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .dropdown-popover {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 140px;
    background: rgba(20, 20, 25, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
    z-index: 100;
  }

  .custom-dropdown.open .dropdown-popover {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-popover :global(.dropdown-item) {
    padding: 8px 12px;
    border-radius: 8px;
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .dropdown-popover :global(.dropdown-item:hover) {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  .dropdown-popover :global(.dropdown-item.active) {
    background: var(--active-color, rgba(255, 255, 255, 0.1));
    color: #fff;
  }

  @keyframes pulse {
    0% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
    100% {
      opacity: 0.5;
    }
  }

  .yearly-stats-container :global(.stats-list) {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
</style>

<script>
  import Chart from "chart.js/auto";
  import {
    generateScrobbleRowHTML,
    applyCountGlows,
    getArtworkUrl,
  } from "../utils/ui";

  // State
  let rawStats: any = null;
  let activeYear: string | null = null;
  let activeCategory: "tracks" | "albums" | "artists" = "tracks";

  interface YearlyTotals {
    [year: string]: number[];
  }

  document.addEventListener("DOMContentLoaded", () => {
    let rawTotals: YearlyTotals | null = null;
    let metaDict: any = null;
    let artworkCache: Record<string, string> = {};

    let chart: Chart | null = null;
    const selectedYears = new Set<string>();
    const datasetMap = new Map<string, any>();

    const checkboxGroup = document.getElementById(
      "yearCheckboxes",
    ) as HTMLDivElement;

    const colors = [
      "#ff2d55",
      "#00f0ff",
      "#a855f7",
      "#22c55e",
      "#f97316",
      "#eab308",
    ];
    let yearColorMap: { [year: string]: string } = {};

    const generateLabels = (): string[] => {
      const labels = [];
      const d = new Date(2024, 0, 1);
      for (let i = 0; i < 366; i++) {
        labels.push(
          d.toLocaleDateString("en-US", { month: "short", day: "numeric" }),
        );
        d.setDate(d.getDate() + 1);
      }
      return labels;
    };
    const xLabels = generateLabels();

    async function loadData() {
      try {
        const [totalsRes, statsRes, metaRes, artworkRes] = await Promise.all([
          fetch("/data/yearly-totals.json"),
          fetch("/data/yearly-stats.json"),
          fetch("/data/meta.json"),
          fetch("/data/artwork.json"),
        ]);
        rawTotals = await totalsRes.json();
        rawStats = await statsRes.json();
        metaDict = await metaRes.json();
        if (artworkRes.ok) {
          artworkCache = await artworkRes.json();
        }

        initializeCheckboxes(rawTotals!);
        updateChart();
        renderYearlyStats();
      } catch (err) {
        console.error("Failed to load statistics data:", err);
      }
    }

    function hexToRgba(hex: string, alpha: number): string {
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    function buildDataset(year: string, totals: YearlyTotals): any {
      const ctx = (
        document.getElementById("yearlyCompareChart") as HTMLCanvasElement
      )?.getContext("2d");
      if (!ctx) return null;

      const color = yearColorMap[year] || "#888";
      const dailyCounts = totals[year] || [];

      let sum = 0;
      let chartData = dailyCounts.map((count) => {
        sum += count;
        return sum;
      });

      const gradient = ctx.createLinearGradient(0, 0, 0, 320);
      gradient.addColorStop(0, hexToRgba(color, 0.18));
      gradient.addColorStop(0.5, hexToRgba(color, 0.06));
      gradient.addColorStop(1, "rgba(0, 0, 0, 0)");

      return {
        label: year,
        data: chartData,
        borderColor: color,
        borderWidth: 2.5,
        backgroundColor: gradient,
        fill: true,
        tension: 0.35,
        pointRadius: 0,
        pointHoverRadius: 4,
        pointHitRadius: 15,
        pointHoverBackgroundColor: "#fff",
        pointHoverBorderColor: color,
        pointHoverBorderWidth: 2,
      };
    }

    function ensureChart() {
      if (chart) return;
      const ctx = (
        document.getElementById("yearlyCompareChart") as HTMLCanvasElement
      )?.getContext("2d");
      if (!ctx) return;

      chart = new Chart(ctx, {
        type: "line",
        data: { labels: xLabels, datasets: [] },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: { duration: 400, easing: "easeInOutQuart" },
          plugins: {
            legend: { display: false },
            tooltip: {
              mode: "nearest",
              intersect: true,
              backgroundColor: "rgba(10, 10, 15, 0.9)",
              titleColor: "#fff",
              bodyColor: "rgba(255,255,255,0.8)",
              borderColor: "rgba(255, 255, 255, 0.1)",
              borderWidth: 1,
              padding: 16,
              cornerRadius: 12,
              usePointStyle: true,
              boxWidth: 8,
              boxHeight: 8,
              boxPadding: 8,
              titleFont: {
                family: "Outfit",
                weight: "bold" as const,
                size: 18,
              },
              bodyFont: { family: "Inter", size: 15 },
              callbacks: {
                label: (context) => {
                  let label = context.dataset.label || "";
                  if (label) label += ": ";
                  if (context.parsed.y !== null) {
                    label += context.parsed.y.toLocaleString() + " plays";
                  }
                  return label;
                },
              },
            },
          },
          interaction: { mode: "nearest", intersect: true },
          scales: {
            x: {
              grid: { display: false },
              ticks: {
                color: "rgba(255,255,255,0.3)",
                font: { family: "Inter", size: 10 },
                maxTicksLimit: 12,
              },
              border: { display: false },
            },
            y: {
              grid: { color: "rgba(255,255,255,0.03)" },
              ticks: {
                color: "rgba(255,255,255,0.3)",
                font: { family: "Inter", size: 10 },
              },
              border: { display: false },
            },
          },
        },
      });
    }

    function updateDropdownsUI() {
      const yearPopover = document.getElementById("yearDropdownPopover");
      if (yearPopover) {
        const sortedSelectedYears = Array.from(selectedYears).sort().reverse();
        yearPopover.innerHTML = sortedSelectedYears
          .map(
            (year) => `
          <div class="dropdown-item ${year === activeYear ? "active" : ""}" data-val="${year}">
            ${year}
          </div>
        `,
          )
          .join("");
      }

      document.getElementById("yearDropdownText")!.innerText =
        activeYear || "Select";

      const catText =
        activeCategory === "tracks"
          ? "Songs"
          : activeCategory === "albums"
            ? "Albums"
            : "Artists";
      document.getElementById("categoryDropdownText")!.innerText = catText;

      document
        .querySelectorAll("#categoryDropdownPopover .dropdown-item")
        .forEach((item) => {
          item.classList.toggle(
            "active",
            item.getAttribute("data-val") === activeCategory,
          );
        });

      const color = activeYear ? yearColorMap[activeYear] : "#ffffff";
      document.documentElement.style.setProperty(
        "--active-color",
        color + "40",
      );

      const card = document.getElementById("activeStatsCard");
      if (card && activeYear) {
        card.style.borderColor = color + "40";
        card.style.boxShadow = `0 8px 32px ${color}15`;

        const yearBtn = document.getElementById("yearDropdownBtn");
        if (yearBtn) {
          yearBtn.style.color = color;
          yearBtn.style.borderColor = color + "40";
          yearBtn.style.background = color + "10";
        }
      }
    }

    function renderYearlyStats() {
      const container = document.getElementById("activeStatsList");
      if (!container || !rawStats || !metaDict || selectedYears.size === 0) {
        if (container) container.innerHTML = "";
        const card = document.getElementById("activeStatsCard");
        if (card) card.style.display = "none";
        return;
      }

      const card = document.getElementById("activeStatsCard");
      if (card) card.style.display = "flex";

      const sortedSelectedYears = Array.from(selectedYears).sort().reverse();
      if (!activeYear || !selectedYears.has(activeYear)) {
        activeYear = sortedSelectedYears[0];
      }

      updateDropdownsUI();

      const stats = rawStats[activeYear];
      if (!stats) {
        container.innerHTML = "";
        return;
      }

      const items = stats[activeCategory] || [];

      const renderList = (
        items: any[],
        type: "artists" | "albums" | "tracks",
      ) =>
        items
          .map((item, idx) => {
            const id = item[0];
            const count = item[1];
            let name = "Unknown";
            let subtitle = "";
            let imgUrl = null;
            let rowType = "artist";

            if (type === "tracks" && metaDict.tracks[id]) {
              name = metaDict.tracks[id][0];
              const artistId = metaDict.tracks[id][1];
              const albumId = metaDict.tracks[id][2];
              const artistName = metaDict.artists[artistId] || "Unknown Artist";
              const albumName = metaDict.albums[albumId] || "Unknown Album";
              subtitle = artistName;
              rowType = "track";
              imgUrl = getArtworkUrl(
                "track",
                name,
                artistName,
                albumName,
                artworkCache,
              );
            } else if (type === "albums" && metaDict.albums[id]) {
              name = metaDict.albums[id];
              const trackEntry = metaDict.tracks.find(
                (t: any) => t && t[2] == id,
              );
              if (trackEntry) {
                const artistName = metaDict.artists[trackEntry[1]];
                subtitle = artistName;
                imgUrl = getArtworkUrl(
                  "album",
                  name,
                  artistName,
                  name,
                  artworkCache,
                );
              } else {
                subtitle = "Album";
                imgUrl = getArtworkUrl("album", name, "", name, artworkCache);
              }
              rowType = "album";
            } else if (type === "artists" && metaDict.artists[id]) {
              name = metaDict.artists[id];
              subtitle = "Artist";
              rowType = "artist";
              imgUrl = getArtworkUrl("artist", name, name, "", artworkCache);
            }

            const idStr = id.toString();

            return generateScrobbleRowHTML(
              {
                type: rowType,
                id: idStr,
                name: name,
                subtitle: subtitle,
                imgUrl: imgUrl || null,
                count: count,
              },
              false,
            );
          })
          .join("");

      container.innerHTML = renderList(items, activeCategory);
      applyCountGlows(container);
    }

    function updateChart() {
      if (!chart) return;

      // Remove unselected datasets
      for (let i = chart.data.datasets.length - 1; i >= 0; i--) {
        if (!selectedYears.has(chart.data.datasets[i].label as string)) {
          chart.data.datasets.splice(i, 1);
        }
      }

      // Add newly selected datasets
      const currentLabels = new Set(chart.data.datasets.map((d: any) => d.label));
      const sortedYears = Array.from(selectedYears).sort().reverse();

      for (const year of sortedYears) {
        if (!currentLabels.has(year)) {
          const ds = buildDataset(year, rawTotals!);
          if (ds) {
            chart.data.datasets.push(ds);
          }
        }
      }

      chart.update();
    }

    function initializeCheckboxes(totals: YearlyTotals) {
      const years = Object.keys(totals)
        .filter((y) => {
          const parsed = parseInt(y, 10);
          return !isNaN(parsed) && parsed >= 2023;
        })
        .sort()
        .reverse();
      years.forEach((year, idx) => {
        yearColorMap[year] = colors[idx % colors.length];
      });

      checkboxGroup.innerHTML = years
        .map((year, idx) => {
          const color = yearColorMap[year];
          const glow = hexToRgba(color, 0.4);
          const ledGlow = hexToRgba(color, 0.85);
          selectedYears.add(year);
          return `
          <label class="checkbox-label checked" 
                 style="--year-color: ${color}; --year-color-glow: ${glow}; --year-led-glow: ${ledGlow};" 
                 data-year="${year}">
            <input type="checkbox" value="${year}" checked />
            <span class="led-indicator"></span>
            <span class="year-text">${year}</span>
          </label>
        `;
        })
        .join("");
    }

    // Event Listeners
    document
      .getElementById("yearCheckboxes")
      ?.addEventListener("change", (e) => {
        const target = e.target as HTMLInputElement;
        if (target.tagName !== "INPUT") return;

        const year = target.value;
        if (target.checked) {
          selectedYears.add(year);
        } else {
          selectedYears.delete(year);
        }

        target.closest("label")?.classList.toggle("checked", target.checked);
        updateChart();
        renderYearlyStats();
      });

    // Delegation for clicking entities and dropdowns
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;

      // Close dropdowns if clicking outside
      if (!target.closest(".custom-dropdown")) {
        document
          .querySelectorAll(".custom-dropdown")
          .forEach((el) => el.classList.remove("open"));
      }

      // Handle dropdown triggers
      const trigger = target.closest(".dropdown-trigger");
      if (trigger) {
        const container = trigger.closest(".custom-dropdown");
        const wasOpen = container?.classList.contains("open");
        document
          .querySelectorAll(".custom-dropdown")
          .forEach((el) => el.classList.remove("open"));
        if (!wasOpen) {
          container?.classList.add("open");
        }
        return;
      }

      // Handle dropdown item selection
      const dropItem = target.closest(".dropdown-item");
      if (dropItem) {
        const val = dropItem.getAttribute("data-val");
        const container = dropItem.closest("#yearDropdownContainer");
        if (container && val) {
          activeYear = val;
        } else if (val) {
          activeCategory = val as any;
        }
        document
          .querySelectorAll(".custom-dropdown")
          .forEach((el) => el.classList.remove("open"));
        renderYearlyStats();
        return;
      }

      // Handle entity clicks
      const entity = target.closest(".clickable-entity");
      if (entity && target.closest("#activeStatsList")) {
        const type = entity.getAttribute("data-type");
        const idStr = entity.getAttribute("data-id");
        if (type && idStr && idStr !== "0") {
          window.dispatchEvent(
            new CustomEvent("open-entity-details", {
              detail: { type, id: parseInt(idStr, 10) },
            }),
          );
        }
      }
    });

    // Horizontal swipe logic
    let touchStartX = 0;
    let touchStartY = 0;
    const statsContainer = document.getElementById("activeStatsCard");
    if (statsContainer) {
      statsContainer.addEventListener(
        "touchstart",
        (e) => {
          touchStartX = e.changedTouches[0].screenX;
          touchStartY = e.changedTouches[0].screenY;
        },
        { passive: true },
      );

      statsContainer.addEventListener(
        "touchend",
        (e) => {
          const touchEndX = e.changedTouches[0].screenX;
          const touchEndY = e.changedTouches[0].screenY;
          const diffX = touchStartX - touchEndX;
          const diffY = touchStartY - touchEndY;

          // 50px threshold to minimize accidental swipes
          if (Math.abs(diffX) > 50 && Math.abs(diffX) > Math.abs(diffY)) {
            const sortedSelectedYears = Array.from(selectedYears)
              .sort()
              .reverse();
            const target = e.target as HTMLElement;

            if (target.closest("#categoryDropdownContainer")) {
              const cats = ["tracks", "albums", "artists"];
              let idx = cats.indexOf(activeCategory);
              if (diffX > 0) idx = Math.min(idx + 1, 2);
              else idx = Math.max(idx - 1, 0);
              activeCategory = cats[idx] as any;
              renderYearlyStats();
            } else if (activeYear) {
              let idx = sortedSelectedYears.indexOf(activeYear);
              if (diffX > 0)
                idx = Math.min(idx + 1, sortedSelectedYears.length - 1); // Swipe left = older year
              else idx = Math.max(idx - 1, 0); // Swipe right = newer year
              
              if (activeYear !== sortedSelectedYears[idx]) {
                activeYear = sortedSelectedYears[idx];
                renderYearlyStats();
              }
            }
          }
        },
        { passive: true },
      );
    }

    window.addEventListener("tab-change", (e: any) => {
      if (e.detail.tab === "statistics") {
        setTimeout(() => {
          if (chart) chart.resize();
        }, 50);
      }
    });

    // Init
    ensureChart();
    loadData();
  });
</script>
