---
// BottomNav component
---

<nav class="bottom-nav-container">
  <!-- Primary Navigation Buttons -->
  <div class="main-tab-bar glass-card">
    <div class="nav-slider-highlight" id="navSliderHighlight"></div>
    <button class="tab-btn active" data-tab="dashboard" aria-label="Dashboard">
      <svg
        class="tab-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="3" y="3" width="7" height="9"></rect>
        <rect x="14" y="3" width="7" height="5"></rect>
        <rect x="14" y="12" width="7" height="9"></rect>
        <rect x="3" y="16" width="7" height="5"></rect>
      </svg>
      <span class="tab-label">Dashboard</span>
    </button>

    <button class="tab-btn" data-tab="rankings" aria-label="Rankings">
      <svg
        class="tab-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="20" x2="18" y2="10"></line>
        <line x1="12" y1="20" x2="12" y2="4"></line>
        <line x1="6" y1="20" x2="6" y2="14"></line>
      </svg>
      <span class="tab-label">Rankings</span>
    </button>

    <button class="tab-btn" data-tab="recents" aria-label="Recent Plays">
      <svg
        class="tab-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <span class="tab-label">Recents</span>
    </button>

    <button class="tab-btn" data-tab="statistics" aria-label="Statistics">
      <svg
        class="tab-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
      </svg>
      <span class="tab-label">Statistics</span>
    </button>
  </div>
</nav>

<style>
  /* Base Mobile View Layout */
  .bottom-nav-container {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 16px env(safe-area-inset-bottom) 16px;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
    transition: var(--transition-smooth);
  }

  /* Main Tab Bar */
  .main-tab-bar {
    width: 100%;
    max-width: 500px;
    height: 64px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 24px;
    background: rgba(10, 10, 10, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
    margin-bottom: 16px;
    padding: 8px; /* Safe padding for absolute highlight */
    pointer-events: auto; /* Enable interaction */
    position: relative;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
  }

  .tab-btn {
    background: none;
    border: none;
    outline: none;
    color: var(--text-secondary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex: 1; /* Equally divide space in 3 chunks */
    height: 48px;
    border-radius: 16px;
    cursor: pointer;
    transition: var(--transition-smooth);
    position: relative;
    z-index: 2; /* Sit above the sliding highlight */
  }

  .tab-icon {
    width: 20px;
    height: 20px;
    transition: var(--transition-smooth);
    flex-shrink: 0;
  }

  .tab-label {
    font-size: 10px;
    font-weight: 500;
    font-family: var(--font-body);
    transition: var(--transition-smooth);
  }

  /* Active states */
  .tab-btn.active {
    color: #fff;
  }

  .tab-btn[data-tab="dashboard"].active {
    color: var(--accent-pink);
    text-shadow: 0 0 10px var(--accent-pink-glow);
  }
  .tab-btn[data-tab="dashboard"].active .tab-icon {
    stroke: var(--accent-pink);
    filter: drop-shadow(0 0 4px var(--accent-pink-glow));
  }

  .tab-btn[data-tab="rankings"].active {
    color: var(--accent-cyan);
    text-shadow: 0 0 10px var(--accent-cyan-glow);
  }
  .tab-btn[data-tab="rankings"].active .tab-icon {
    stroke: var(--accent-cyan);
    filter: drop-shadow(0 0 4px var(--accent-cyan-glow));
  }

  .tab-btn[data-tab="recents"].active {
    color: var(--accent-violet);
    text-shadow: 0 0 10px var(--accent-violet-glow);
  }
  .tab-btn[data-tab="recents"].active .tab-icon {
    stroke: var(--accent-violet);
    filter: drop-shadow(0 0 4px var(--accent-violet-glow));
  }

  .tab-btn[data-tab="statistics"].active {
    color: var(--accent-green);
    text-shadow: 0 0 10px var(--accent-green-glow);
  }
  .tab-btn[data-tab="statistics"].active .tab-icon {
    stroke: var(--accent-green);
    filter: drop-shadow(0 0 4px var(--accent-green-glow));
  }

  /* Apple Music Style sliding tab bar highlight pill */
  .nav-slider-highlight {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 1;
    background: color-mix(in srgb, var(--hl-color, rgba(255, 255, 255, 0.25)) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--hl-color, rgba(255, 255, 255, 0.4)) 40%, transparent);
    border-radius: 16px;
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.3),
      0 4px 12px var(--hl-glow, rgba(0, 0, 0, 0.4));
    transition:
      transform 0.35s cubic-bezier(0.25, 1, 0.5, 1),
      width 0.35s cubic-bezier(0.25, 1, 0.5, 1),
      height 0.35s cubic-bezier(0.25, 1, 0.5, 1),
      background-color 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;
    will-change: transform, width, height, background-color, border-color, box-shadow;
    pointer-events: none;
  }

  .tab-btn:hover {
    color: #fff;
  }

  /* Desktop View: Left Side Bar */
  @media (min-width: 768px) {
    .bottom-nav-container {
      width: 180px;
      height: fit-content;
      position: fixed;
      top: 50%;
      bottom: auto;
      left: 24px;
      right: auto;
      transform: translateY(-50%);
      flex-direction: column;
      justify-content: flex-start;
      align-items: stretch;
      padding: 16px;
      background: rgba(10, 10, 10, 0.85);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      pointer-events: auto;
    }

    .main-tab-bar {
      flex-direction: column;
      background: transparent;
      border: none;
      box-shadow: none;
      width: 100%;
      gap: 8px;
      padding: 0;
      height: auto;
      justify-content: flex-start;
      align-items: stretch;
      position: relative;
    }

    .tab-btn {
      width: 100%;
      height: 48px;
      border-radius: 12px;
      padding: 0 16px;
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: flex-start !important;
      gap: 12px;
      flex: none;
    }

    .tab-label {
      font-size: 15px;
      font-weight: 500;
      display: block;
    }
  }
</style>

<script>
  // Setup Client-side Navigation Router
  function initNav() {
    const tabs = document.querySelectorAll(".tab-btn");
    const highlight = document.getElementById("navSliderHighlight");
    const activeTab = document.querySelector(".tab-btn.active") as HTMLElement;
    console.log("initNav elements:", {
      tabsCount: tabs.length,
      highlight,
      activeTab,
    });

    function syncHighlight(activeBtn: HTMLElement) {
      if (!highlight || !activeBtn) {
        console.warn("syncHighlight skipped - missing elements:", {
          highlight,
          activeBtn,
        });
        return;
      }
      console.log("syncHighlight coordinates:", {
        offsetLeft: activeBtn.offsetLeft,
        offsetTop: activeBtn.offsetTop,
        offsetWidth: activeBtn.offsetWidth,
        offsetHeight: activeBtn.offsetHeight,
      });
      highlight.style.transform = `translate3d(${activeBtn.offsetLeft}px, ${activeBtn.offsetTop}px, 0)`;
      highlight.style.width = `${activeBtn.offsetWidth}px`;
      highlight.style.height = `${activeBtn.offsetHeight}px`;

      const tabName = activeBtn.getAttribute("data-tab");
      let color = "rgba(255,255,255,0.25)";
      let glow = "rgba(0,0,0,0.4)";
      
      if (tabName === "dashboard") { color = "var(--accent-pink)"; glow = "var(--accent-pink-glow)"; }
      else if (tabName === "rankings") { color = "var(--accent-cyan)"; glow = "var(--accent-cyan-glow)"; }
      else if (tabName === "recents") { color = "var(--accent-violet)"; glow = "var(--accent-violet-glow)"; }
      else if (tabName === "statistics") { color = "var(--accent-green)"; glow = "var(--accent-green-glow)"; }
      
      highlight.style.setProperty("--hl-color", color);
      highlight.style.setProperty("--hl-glow", glow);
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const targetTab = tab.getAttribute("data-tab");
        if (!targetTab) return;

        // Update active class on buttons
        tabs.forEach((t) => t.classList.remove("active"));
        tab.classList.add("active");

        syncHighlight(tab as HTMLElement);

        // Fire custom event to notify parent layout to switch views
        const event = new CustomEvent("tab-change", {
          detail: { tab: targetTab },
        });
        window.dispatchEvent(event);
      });
    });

    // Initial sync
    if (activeTab) {
      syncHighlight(activeTab);
      // Wait for rendering layout calculations
      setTimeout(() => syncHighlight(activeTab), 100);
      setTimeout(() => syncHighlight(activeTab), 300);
      setTimeout(() => syncHighlight(activeTab), 600);
    }

    // Resize sync
    window.addEventListener("resize", () => {
      const active = document.querySelector(".tab-btn.active") as HTMLElement;
      if (active) syncHighlight(active);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNav);
  } else {
    initNav();
  }
</script>
